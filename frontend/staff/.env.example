# API
VITE_API_BASE_URL=https://localhost:7000/api/v1

# Microsoft Entra External ID (CIAM) — same tenant as the portal, separate app registration
# Tenant name is the subdomain of your External ID tenant (e.g. "herit" → herit.ciamlogin.com)
# VITE_AZURE_CLIENT_ID is the staff SPA's OWN app registration (distinct from the portal's).
VITE_AZURE_CLIENT_ID=your-entra-external-id-staff-spa-client-id
VITE_AZURE_TENANT_NAME=your-entra-external-id-tenant-name
VITE_AZURE_AUTHORITY=https://your-entra-external-id-tenant-name.ciamlogin.com/your-entra-external-id-tenant-name.onmicrosoft.com/
VITE_REDIRECT_URI=http://localhost:5174

# The API app registration's client id. The requested scope is built in code as
# api://${VITE_AZURE_API_CLIENT_ID}/access_as_user.
VITE_AZURE_API_CLIENT_ID=your-api-client-id

# Portal URL — used by the sign-in / access-denied pages to link back to the
# public portal. Defaults to https://herit.app when unset.
VITE_PORTAL_URL=http://localhost:5173
