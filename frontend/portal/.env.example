# API
VITE_API_BASE_URL=https://localhost:7000/api/v1

# Microsoft Entra External ID (CIAM)
# Tenant name is the subdomain of your External ID tenant (e.g. "herit" → herit.ciamlogin.com)
VITE_AZURE_CLIENT_ID=your-entra-external-id-client-id
VITE_AZURE_TENANT_NAME=your-entra-external-id-tenant-name
VITE_REDIRECT_URI=http://localhost:5173

# API scope registered in Entra External ID
VITE_API_SCOPE=api://your-api-client-id/access_as_user
